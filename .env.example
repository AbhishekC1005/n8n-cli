# ── NVIDIA NIM API ──────────────────────────────────────────────
# Get your free API key at: https://build.nvidia.com/
NIM_API_KEY=nvapi-your-key-here
NVIDIA_NIM_API_KEY=nvapi-your-key-here
NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# Model to use (must be prefixed with openai/ for LiteLLM)
# Working models: openai/meta/llama-3.3-70b-instruct, openai/deepseek-ai/deepseek-v4-flash
MODEL=openai/deepseek-ai/deepseek-v4-flash

# ── n8n Connection ─────────────────────────────────────────────
# Generate an API key in n8n: Settings → API → Create API Key
N8N_API_KEY=your-n8n-api-key-here
N8N_BASE_URL=http://localhost:5678

# ── Optional ────────────────────────────────────────────────────
CACHE_TTL=3600
